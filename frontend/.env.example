# Backend origin only — no trailing slash, no /api suffix.
#
# Local:
# VITE_API_URL=http://127.0.0.1:8000
#
# Vercel (production): set the same variable in the Vercel project → Settings → Environment Variables:
# VITE_API_URL=https://your-service.onrender.com
# Then add https://your-app.vercel.app to backend CORS_ORIGINS on Render.
