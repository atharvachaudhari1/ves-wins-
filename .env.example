# Backend
HOST=0.0.0.0
PORT=8000
MAX_IMAGE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
DEEPFACE_MODEL=Facenet
# Comma-separated; include both hostname styles if you use localhost vs 127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Optional: set to true to run DeepFace.verify (requires TensorFlow stack)
USE_DEEPFACE=false
